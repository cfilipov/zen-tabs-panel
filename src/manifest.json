{
  "manifest_version": 2,
  "name": "ErgoZen",
  "version": "0.4.6",
  "description": "Command palette for Zen Browser. Discoverable chord shortcuts for tabs, workspaces, splits, and more.",
  "author": "c13v",
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-tabs-panel@c13v.com",
      "strict_min_version": "128.0"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; img-src 'self' data: resource:;",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "sessions",
    "menus",
    "clipboardWrite",
    "history",
    "contextualIdentities",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "experiment_apis": {
    "zenWorkspaces": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "paths": [
          [
            "zenWorkspaces"
          ]
        ],
        "script": "experiment/api.js"
      }
    }
  },
  "background": {
    "scripts": [
      "shared/constants.js",
      "shared/navigation-url.js",
      "lib/tab-sort.js",
      "background/auto-action-gatekeeper.js",
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "ErgoZen"
  },
  "commands": {
    "open-palette": {
      "suggested_key": {
        "default": "Command+Period"
      },
      "description": "Open palette / arm chord"
    },
    "open-palette-2": {
      "suggested_key": {
        "default": "Command+Alt+Period"
      },
      "description": "Open palette / arm chord (alternate)"
    },
    "open-command-palette": {
      "suggested_key": {
        "default": "Command+Shift+P"
      },
      "description": "Open command palette"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}
