{
  "name": "ergozen",
  "private": true,
  "version": "0.4.5",
  "description": "Tab management command palette and utilities for Zen Browser",
  "scripts": {
    "build": "node scripts/build-extension.mjs",
    "test": "npm run test:node && npm run test:svelte",
    "test:node": "node --test tests/*.test.js",
    "test:svelte": "vitest run",
    "typecheck": "tsc --noEmit",
    "screenshots:readme": "python3 tools/readme-screenshots.py",
    "smoke": "tools/popup-smoke.py",
    "smoke:popup": "tools/popup-smoke.py",
    "smoke:chord": "python3 tools/chord-integration-smoke.py"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.8.0",
    "jsdom": "^29.1.1",
    "lucide-static": "^1.16.0",
    "svelte": "^5.55.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
