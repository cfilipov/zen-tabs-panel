{
  "name": "zen-tabs-panel",
  "private": true,
  "version": "0.3.0",
  "description": "Tab management command palette and utilities for Zen Browser",
  "scripts": {
    "build": "npm run build:svelte",
    "build:vanilla": "node scripts/build-extension.mjs --variant=vanilla",
    "build:svelte": "node scripts/build-extension.mjs --variant=svelte",
    "test": "npm run test:node && npm run test:svelte",
    "test:node": "node --test tests/*.test.js",
    "test:svelte": "vitest run",
    "smoke:popup": "tools/popup-smoke.py"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
